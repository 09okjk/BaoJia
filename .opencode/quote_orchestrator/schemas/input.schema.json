{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/opencode/quote_orchestrator/input.schema.json",
  "title": "quote_orchestrator input",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "assessment_report"
  ],
  "properties": {
    "assessment_report": {
      "type": "object"
    },
    "customer_context": {
      "type": "object"
    },
    "business_context": {
      "type": "object"
    },
    "render_options": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "languages": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["zh", "en"]
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "output_dir": {
          "type": "string"
        }
      }
    }
  }
}
