{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/opencode/skills/quote_template_select_skill/output.schema.json",
  "title": "quote_template_select_skill output",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "template_selection_result"
  ],
  "properties": {
    "template_selection_result": {
      "$ref": "#/$defs/templateSelectionResult"
    }
  },
  "$defs": {
    "templateType": {
      "type": "string",
      "enum": [
        "engineering-service",
        "digital-product",
        "laboratory",
        "man-hour",
        "product",
        "supercharger",
        "valva"
      ]
    },
    "signal": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "signal",
        "source",
        "weight",
        "supports"
      ],
      "properties": {
        "signal": {
          "type": "string"
        },
        "source": {
          "type": "string"
        },
        "weight": {
          "type": "number"
        },
        "supports": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/templateType"
          },
          "minItems": 1,
          "uniqueItems": true
        }
      }
    },
    "ruleScores": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "engineering-service",
        "digital-product",
        "laboratory",
        "man-hour",
        "product",
        "supercharger",
        "valva"
      ],
      "properties": {
        "engineering-service": { "type": "number" },
        "digital-product": { "type": "number" },
        "laboratory": { "type": "number" },
        "man-hour": { "type": "number" },
        "product": { "type": "number" },
        "supercharger": { "type": "number" },
        "valva": { "type": "number" }
      }
    },
    "templateSelectionResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "template_type",
        "confidence",
        "candidate_templates",
        "rule_scores",
        "reasons",
        "matched_signals",
        "needs_manual_confirmation",
        "questions_for_user",
        "review_flags"
      ],
      "properties": {
        "template_type": {
          "$ref": "#/$defs/templateType"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "candidate_templates": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/templateType"
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "rule_scores": {
          "$ref": "#/$defs/ruleScores"
        },
        "reasons": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "matched_signals": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/signal"
          }
        },
        "needs_manual_confirmation": {
          "type": "boolean"
        },
        "questions_for_user": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "review_flags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
