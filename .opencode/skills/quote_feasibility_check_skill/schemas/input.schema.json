{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/opencode/skills/quote_feasibility_check_skill/input.schema.json",
  "title": "quote_feasibility_check_skill input",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "quote_request"
  ],
  "properties": {
    "quote_request": {
      "$ref": "#/$defs/quoteRequest"
    }
  },
  "$defs": {
    "nullableString": {
      "type": [
        "string",
        "null"
      ]
    },
    "stringArray": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "requestMeta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "request_id",
        "source",
        "prepared_at",
        "language"
      ],
      "properties": {
        "request_id": {
          "$ref": "#/$defs/nullableString"
        },
        "source": {
          "type": "string",
          "const": "assessment_report"
        },
        "prepared_at": {
          "$ref": "#/$defs/nullableString"
        },
        "language": {
          "type": "string"
        }
      }
    },
    "headerContext": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "currency",
        "vessel_name",
        "imo_no",
        "vessel_type",
        "customer_name",
        "service_port",
        "service_date",
        "attention",
        "customer_ref_no"
      ],
      "properties": {
        "currency": {
          "$ref": "#/$defs/nullableString"
        },
        "vessel_name": {
          "$ref": "#/$defs/nullableString"
        },
        "imo_no": {
          "$ref": "#/$defs/nullableString"
        },
        "vessel_type": {
          "$ref": "#/$defs/nullableString"
        },
        "customer_name": {
          "$ref": "#/$defs/nullableString"
        },
        "service_port": {
          "$ref": "#/$defs/nullableString"
        },
        "service_date": {
          "$ref": "#/$defs/nullableString"
        },
        "attention": {
          "$ref": "#/$defs/nullableString"
        },
        "customer_ref_no": {
          "$ref": "#/$defs/nullableString"
        }
      }
    },
    "serviceContext": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "service_category",
        "service_mode",
        "location_type",
        "needs_multi_option",
        "option_hints",
        "urgency"
      ],
      "properties": {
        "service_category": {
          "$ref": "#/$defs/nullableString"
        },
        "service_mode": {
          "$ref": "#/$defs/nullableString"
        },
        "location_type": {
          "$ref": "#/$defs/nullableString"
        },
        "needs_multi_option": {
          "type": "boolean"
        },
        "option_hints": {
          "$ref": "#/$defs/stringArray"
        },
        "urgency": {
          "$ref": "#/$defs/nullableString"
        }
      }
    },
    "candidateItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "item_id",
        "item_type",
        "title",
        "description",
        "work_scope",
        "quantity_hint",
        "unit_hint",
        "labor_hint",
        "pricing_clues",
        "status_hint",
        "source"
      ],
      "properties": {
        "item_id": {
          "type": "string"
        },
        "item_type": {
          "type": "string",
          "enum": [
            "service",
            "spare_parts",
            "other"
          ]
        },
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "work_scope": {
          "$ref": "#/$defs/stringArray"
        },
        "quantity_hint": {
          "type": [
            "number",
            "integer",
            "string",
            "null"
          ]
        },
        "unit_hint": {
          "$ref": "#/$defs/nullableString"
        },
        "labor_hint": {
          "$ref": "#/$defs/stringArray"
        },
        "pricing_clues": {
          "$ref": "#/$defs/stringArray"
        },
        "status_hint": {
          "$ref": "#/$defs/nullableString"
        },
        "source": {
          "type": "string",
          "const": "assessment_report"
        }
      }
    },
    "sparePartsContext": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "has_spare_parts",
        "spare_parts_supply_mode",
        "spare_parts_items"
      ],
      "properties": {
        "has_spare_parts": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "spare_parts_supply_mode": {
          "$ref": "#/$defs/nullableString"
        },
        "spare_parts_items": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/candidateItem"
          }
        }
      }
    },
    "riskContext": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "risks",
        "pending_confirmations",
        "assumptions"
      ],
      "properties": {
        "risks": {
          "$ref": "#/$defs/stringArray"
        },
        "pending_confirmations": {
          "$ref": "#/$defs/stringArray"
        },
        "assumptions": {
          "$ref": "#/$defs/stringArray"
        }
      }
    },
    "commercialContext": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "preferred_currency",
        "pricing_expectation",
        "special_terms"
      ],
      "properties": {
        "preferred_currency": {
          "$ref": "#/$defs/nullableString"
        },
        "pricing_expectation": {
          "$ref": "#/$defs/nullableString"
        },
        "special_terms": {
          "$ref": "#/$defs/stringArray"
        }
      }
    },
    "sourceRefs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "assessment_report_id",
        "customer_context_ref",
        "business_context_ref"
      ],
      "properties": {
        "assessment_report_id": {
          "$ref": "#/$defs/nullableString"
        },
        "customer_context_ref": {
          "$ref": "#/$defs/nullableString"
        },
        "business_context_ref": {
          "$ref": "#/$defs/nullableString"
        }
      }
    },
    "quoteRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "request_meta",
        "header_context",
        "service_context",
        "candidate_items",
        "spare_parts_context",
        "risk_context",
        "commercial_context",
        "source_refs"
      ],
      "properties": {
        "request_meta": {
          "$ref": "#/$defs/requestMeta"
        },
        "header_context": {
          "$ref": "#/$defs/headerContext"
        },
        "service_context": {
          "$ref": "#/$defs/serviceContext"
        },
        "candidate_items": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/candidateItem"
          }
        },
        "spare_parts_context": {
          "$ref": "#/$defs/sparePartsContext"
        },
        "risk_context": {
          "$ref": "#/$defs/riskContext"
        },
        "commercial_context": {
          "$ref": "#/$defs/commercialContext"
        },
        "source_refs": {
          "$ref": "#/$defs/sourceRefs"
        }
      }
    }
  }
}
