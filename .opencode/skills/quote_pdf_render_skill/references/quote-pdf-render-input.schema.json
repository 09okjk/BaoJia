{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/opencode/skills/quote-pdf-render-skill/references/quote-pdf-render-input.schema.json",
  "title": "quote_pdf_render_skill input",
  "type": "object",
  "required": ["quote_document"],
  "properties": {
    "quote_document": {
      "$ref": "../../../quote-document-v1.1.schema.json"
    },
    "render_options": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "languages": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["zh", "en"]
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "output_dir": {
          "type": "string"
        },
        "template_type": {
          "type": "string",
          "enum": ["engineering-service", "digital-product", "laboratory", "man-hour", "product", "supercharger", "valva"]
        }
      }
    }
  }
}
