{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/opencode/skills/quote_pdf_render_skill/output.schema.json",
  "title": "quote_pdf_render_skill output",
  "type": "object",
  "additionalProperties": false,
  "required": ["render_result"],
  "properties": {
    "render_result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["document_type", "document_version", "outputs"],
      "properties": {
        "document_type": {
          "type": "string",
          "const": "quotation"
        },
        "document_version": {
          "type": "string"
        },
        "outputs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["language", "html_path", "pdf_path", "status"],
            "properties": {
              "language": {
                "type": "string",
                "enum": ["zh", "en"]
              },
              "html_path": {
                "type": "string"
              },
              "pdf_path": {
                "type": "string"
              },
              "status": {
                "type": "string",
                "enum": ["success", "failed"]
              },
              "error": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  }
}
