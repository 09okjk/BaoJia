{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/opencode/skills/historical_quote_reference_skill/output.schema.json",
  "title": "historical_quote_reference_skill output",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "matches",
    "reference_summary",
    "confidence"
  ],
  "properties": {
    "matches": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/match"
      }
    },
    "reference_summary": {
      "$ref": "#/$defs/referenceSummary"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  },
  "$defs": {
    "stringArray": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "nullableNumber": {
      "type": ["number", "null"]
    },
    "nullableString": {
      "type": ["string", "null"]
    },
    "matchPair": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "query_item_id",
        "query_title",
        "reference_item_id",
        "reference_title",
        "similarity",
        "matched_signals"
      ],
      "properties": {
        "query_item_id": { "type": "string" },
        "query_title": { "type": "string" },
        "reference_item_id": { "type": "string" },
        "reference_title": { "type": "string" },
        "similarity": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "matched_signals": { "$ref": "#/$defs/stringArray" }
      }
    },
    "commercialFit": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "spare_parts_supply_mode_match",
        "option_style_overlap"
      ],
      "properties": {
        "spare_parts_supply_mode_match": { "type": "boolean" },
        "option_style_overlap": { "$ref": "#/$defs/stringArray" }
      }
    },
    "match": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "quote_id",
        "similarity",
        "reason",
        "matched_features",
        "reference_items",
        "reference_remarks",
        "match_level",
        "matched_item_pairs",
        "commercial_fit",
        "prefilter_score",
        "semantic_score",
        "rerank_stage"
      ],
      "properties": {
        "quote_id": {
          "type": "string"
        },
        "similarity": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "reason": {
          "type": "string"
        },
        "matched_features": {
          "$ref": "#/$defs/stringArray"
        },
        "reference_items": {
          "$ref": "#/$defs/stringArray"
        },
        "reference_remarks": {
          "$ref": "#/$defs/stringArray"
        },
        "match_level": {
          "type": "string",
          "enum": ["context_only", "item_and_context", "strong_item_match"]
        },
        "matched_item_pairs": {
          "type": "array",
          "items": { "$ref": "#/$defs/matchPair" }
        },
        "commercial_fit": { "$ref": "#/$defs/commercialFit" },
        "prefilter_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "semantic_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "rerank_stage": {
          "type": "string",
          "enum": ["hybrid"]
        }
      }
    },
    "priceRangeHint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "currency",
        "min",
        "max",
        "sample_size"
      ],
      "properties": {
        "currency": {
          "$ref": "#/$defs/nullableString"
        },
        "min": {
          "$ref": "#/$defs/nullableNumber"
        },
        "max": {
          "$ref": "#/$defs/nullableNumber"
        },
        "sample_size": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "countedTextBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sample_size", "examples"],
      "properties": {
        "sample_size": {
          "type": "integer",
          "minimum": 0
        },
        "examples": {
          "$ref": "#/$defs/stringArray"
        }
      }
    },
    "itemCluster": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cluster_key", "sample_size", "examples"],
      "properties": {
        "cluster_key": { "type": "string" },
        "sample_size": { "type": "integer", "minimum": 0 },
        "examples": { "$ref": "#/$defs/stringArray" }
      }
    },
    "remarkBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["remark_type", "texts", "sample_size"],
      "properties": {
        "remark_type": { "type": "string" },
        "texts": { "$ref": "#/$defs/stringArray" },
        "sample_size": { "type": "integer", "minimum": 0 }
      }
    },
    "chargeItemHint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["hint_type", "source", "sample_size", "examples"],
      "properties": {
        "hint_type": { "type": "string" },
        "source": { "type": "string" },
        "sample_size": { "type": "integer", "minimum": 0 },
        "examples": { "$ref": "#/$defs/stringArray" }
      }
    },
    "optionStyleHint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["style_type", "source", "sample_size", "examples"],
      "properties": {
        "style_type": { "type": "string" },
        "source": { "type": "string" },
        "sample_size": { "type": "integer", "minimum": 0 },
        "examples": { "$ref": "#/$defs/stringArray" }
      }
    },
    "itemPriceHint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "query_item_id",
        "query_title",
        "currency",
        "min",
        "max",
        "median",
        "sample_size",
        "matched_reference_item_ids",
        "source_quote_ids"
      ],
      "properties": {
        "query_item_id": { "type": "string" },
        "query_title": { "type": "string" },
        "currency": { "$ref": "#/$defs/nullableString" },
        "min": { "$ref": "#/$defs/nullableNumber" },
        "max": { "$ref": "#/$defs/nullableNumber" },
        "median": { "$ref": "#/$defs/nullableNumber" },
        "sample_size": { "type": "integer", "minimum": 0 },
        "matched_reference_item_ids": { "$ref": "#/$defs/stringArray" },
        "source_quote_ids": { "$ref": "#/$defs/stringArray" }
      }
    },
    "referenceSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "price_range_hint",
        "common_items",
        "remark_patterns",
        "recommended_reference_ids",
        "item_clusters",
        "remark_blocks",
        "charge_item_hints",
        "option_style_hints",
        "history_quality_flags",
        "item_price_hints",
        "retrieval_strategy"
      ],
      "properties": {
        "price_range_hint": {
          "$ref": "#/$defs/priceRangeHint"
        },
        "common_items": {
          "$ref": "#/$defs/stringArray"
        },
        "remark_patterns": {
          "$ref": "#/$defs/stringArray"
        },
        "recommended_reference_ids": {
          "$ref": "#/$defs/stringArray"
        },
        "item_clusters": {
          "type": "array",
          "items": { "$ref": "#/$defs/itemCluster" }
        },
        "remark_blocks": {
          "type": "array",
          "items": { "$ref": "#/$defs/remarkBlock" }
        },
        "charge_item_hints": {
          "type": "array",
          "items": { "$ref": "#/$defs/chargeItemHint" }
        },
        "option_style_hints": {
          "type": "array",
          "items": { "$ref": "#/$defs/optionStyleHint" }
        },
        "history_quality_flags": {
          "$ref": "#/$defs/stringArray"
        },
        "item_price_hints": {
          "type": "array",
          "items": { "$ref": "#/$defs/itemPriceHint" }
        },
        "retrieval_strategy": {
          "type": "string",
          "enum": [
            "rule_prefilter+aliyun_embedding_rerank",
            "rule_prefilter+tfidf_fallback"
          ]
        }
      }
    }
  }
}
